# --- Base de Datos ---
DB_HOST=db
DB_PORT=3306
DB_NAME=inventario_motos
DB_USER=admin
DB_PASS=admin.123

# --- MySQL root (solo para Docker) ---
MYSQL_ROOT_PASSWORD=TU_ROOT_PASSWORD_AQUI

# --- Aplicación ---
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

# --- Stock mínimo por defecto ---
STOCK_MINIMO_ALERTA=5
