{
    "name": "es21plus/sistema-inventario-motos",
    "description": "Sistema de inventario para taller mecánico de motos",
    "type": "project",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "classmap": [
            "src/includes/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "src/tests/",
            "tests/"
        ]
    },
    "scripts": {
        "test": "phpunit --bootstrap src/tests/bootstrap.php src/tests/ tests/Integration/"
    },
    "config": {
        "optimize-autoloader": true
    }
}
